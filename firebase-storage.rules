rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Products folder - anyone can view images, but only authenticated users (admins) can upload
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
